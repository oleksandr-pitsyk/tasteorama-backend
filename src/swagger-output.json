{
  "swagger": "2.0",
  "info": {
    "title": "Tasteorama API",
    "description": "Beautiful and practical API reference for Tasteorama backend.",
    "version": "1.0.0",
    "contact": {
      "name": "Tasteorama Team"
    }
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    {
      "name": "Auth",
      "description": "Register, login, and logout flows."
    },
    {
      "name": "Categories",
      "description": "Recipe category catalog for browsing."
    },
    {
      "name": "Ingredients",
      "description": "Ingredient catalog used by recipes."
    },
    {
      "name": "Recipes",
      "description": "Create and manage custom recipes."
    },
    {
      "name": "Users",
      "description": "Current authenticated user profile."
    },
    {
      "name": "Favorites",
      "description": "Save and remove recipes in favorites."
    }
  ],
  "securityDefinitions": {
    "SessionCookie": {
      "type": "apiKey",
      "in": "header",
      "name": "Cookie",
      "description": "Use /api/auth/login in this Swagger UI session. Browser cookies are stored and sent automatically for private endpoints."
    }
  },
  "definitions": {
    "RegisterRequest": {
      "type": "object",
      "required": ["name", "email", "password"],
      "properties": {
        "name": {
          "type": "string",
          "example": "Sofiia"
        },
        "email": {
          "type": "string",
          "example": "sofiia@example.com"
        },
        "password": {
          "type": "string",
          "example": "StrongPass123"
        }
      }
    },
    "LoginRequest": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {
          "type": "string",
          "example": "sofiia@example.com"
        },
        "password": {
          "type": "string",
          "example": "StrongPass123"
        }
      }
    },
    "RecipeIngredient": {
      "type": "object",
      "required": ["id", "measure"],
      "properties": {
        "id": {
          "type": "string",
          "example": "64f1234567890abcdef1234"
        },
        "measure": {
          "type": "string",
          "example": "200g"
        }
      }
    },
    "UserResponse": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "686f6e9ac1d1a4f95c0ea111"
        },
        "name": {
          "type": "string",
          "example": "Sofiia"
        },
        "email": {
          "type": "string",
          "example": "sofiia@example.com"
        },
        "avatar": {
          "type": "string",
          "example": "https://ac.goit.global/fullstack/react/default-avatar.jpg"
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "recipeId": {
                "type": "string",
                "example": "64f1234567890abcdef1234"
              }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "example": "2026-06-13T10:15:00.000Z"
        },
        "updatedAt": {
          "type": "string",
          "example": "2026-06-13T10:15:00.000Z"
        }
      }
    },
    "CategoryItem": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "686f6e9ac1d1a4f95c0ea211"
        },
        "name": {
          "type": "string",
          "example": "Chicken"
        }
      }
    },
    "IngredientItem": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "686f6e9ac1d1a4f95c0ea311"
        },
        "name": {
          "type": "string",
          "example": "Tomato"
        },
        "desc": {
          "type": "string",
          "example": "Fresh red tomato"
        },
        "img": {
          "type": "string",
          "example": "https://example.com/images/tomato.png"
        }
      }
    },
    "CreateRecipeRequestJson": {
      "type": "object",
      "required": ["title", "category", "instructions", "description", "time", "ingredients"],
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 64,
          "example": "Herb Chicken Bowl"
        },
        "category": {
          "type": "string",
          "description": "Category ObjectId",
          "example": "6462a6cd4c3d0ddd28897f8d"
        },
        "instructions": {
          "type": "string",
          "maxLength": 1200,
          "example": "Cook chicken, slice vegetables, combine and serve."
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "example": "Protein-rich bowl with fresh herbs and lemon dressing."
        },
        "thumb": {
          "type": "string",
          "example": "https://example.com/images/chicken-bowl.jpg"
        },
        "time": {
          "type": "number",
          "minimum": 1,
          "maximum": 360,
          "example": 30
        },
        "calories": {
          "type": "number",
          "minimum": 1,
          "maximum": 10000,
          "example": 450
        },
        "ingredients": {
          "type": "array",
          "minItems": 2,
          "maxItems": 16,
          "items": {
            "$ref": "#/definitions/RecipeIngredient"
          }
        }
      }
    },
    "RecipeResponse": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "686f6e9ac1d1a4f95c0ea411"
        },
        "title": {
          "type": "string",
          "example": "Herb Chicken Bowl"
        },
        "category": {
          "type": "string",
          "example": "Chicken"
        },
        "owner": {
          "type": "string",
          "example": "686f6e9ac1d1a4f95c0ea111"
        },
        "instructions": {
          "type": "string",
          "example": "Cook chicken, slice vegetables, combine and serve."
        },
        "description": {
          "type": "string",
          "example": "Protein-rich bowl with fresh herbs and lemon dressing."
        },
        "thumb": {
          "type": "string",
          "example": "https://example.com/images/chicken-bowl.jpg"
        },
        "time": {
          "type": "string",
          "example": "30"
        },
        "calories": {
          "type": "number",
          "example": 450
        },
        "ingredients": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RecipeIngredient"
          }
        },
        "createdAt": {
          "type": "string",
          "example": "2026-06-13T10:20:00.000Z"
        },
        "updatedAt": {
          "type": "string",
          "example": "2026-06-13T10:20:00.000Z"
        }
      }
    },
    "UserEnvelopeResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Information about the current user"
        },
        "data": {
          "$ref": "#/definitions/UserResponse"
        }
      }
    },
    "CollectionEnvelopeResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "List of categories"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CategoryItem"
          }
        }
      }
    },
    "IngredientCollectionEnvelopeResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "List of ingredients"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/IngredientItem"
          }
        }
      }
    },
    "CreateRecipeSuccessResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Recipe created successfully"
        },
        "data": {
          "$ref": "#/definitions/RecipeResponse"
        }
      }
    },
    "FavoriteSuccessResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Recipe added to favorites"
        }
      }
    },
    "RecipesSearchResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "List of recipes"
        },
        "page": {
          "type": "number",
          "example": 1
        },
        "perPage": {
          "type": "number",
          "example": 12
        },
        "totalItems": {
          "type": "number",
          "example": 47
        },
        "totalPages": {
          "type": "number",
          "example": 4
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RecipeResponse"
          }
        }
      }
    },
    "FavoriteRecipesResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "List of favorite recipes"
        },
        "page": {
          "type": "number",
          "example": 1
        },
        "perPage": {
          "type": "number",
          "example": 12
        },
        "totalItems": {
          "type": "number",
          "example": 12
        },
        "totalPages": {
          "type": "number",
          "example": 1
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RecipeResponse"
          }
        }
      }
    },
    "ApiError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Missing access token"
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create a new account",
        "description": "Registers a new user and prepares account for authenticated actions.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RegisterRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User successfully registered",
            "schema": {
              "$ref": "#/definitions/UserEnvelopeResponse"
            },
            "examples": {
              "application/json": {
                "message": "Information about the new user",
                "data": {
                  "_id": "686f6e9ac1d1a4f95c0ea111",
                  "name": "Sofiia",
                  "email": "sofiia@example.com",
                  "avatar": "https://ac.goit.global/fullstack/react/default-avatar.jpg",
                  "favorites": [],
                  "createdAt": "2026-06-13T10:15:00.000Z",
                  "updatedAt": "2026-06-13T10:15:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or email already in use",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in",
        "description": "Authenticates user and returns session cookies (sessionId, accessToken).",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User authenticated",
            "schema": {
              "$ref": "#/definitions/UserEnvelopeResponse"
            },
            "examples": {
              "application/json": {
                "message": "Information about the current user",
                "data": {
                  "_id": "686f6e9ac1d1a4f95c0ea111",
                  "name": "Sofiia",
                  "email": "sofiia@example.com",
                  "avatar": "https://ac.goit.global/fullstack/react/default-avatar.jpg",
                  "favorites": [
                    {
                      "recipeId": "64f1234567890abcdef1234"
                    }
                  ],
                  "createdAt": "2026-06-13T10:15:00.000Z",
                  "updatedAt": "2026-06-13T10:20:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign out",
        "description": "Invalidates current session for authenticated user. Login first in this Swagger UI session so cookies are sent automatically.",
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "responses": {
          "204": {
            "description": "Logged out successfully"
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "Get all categories",
        "description": "Returns full list of recipe categories.",
        "responses": {
          "200": {
            "description": "Categories list returned",
            "schema": {
              "$ref": "#/definitions/CollectionEnvelopeResponse"
            },
            "examples": {
              "application/json": {
                "message": "List of categories",
                "data": [
                  {
                    "_id": "686f6e9ac1d1a4f95c0ea211",
                    "name": "Beef"
                  },
                  {
                    "_id": "686f6e9ac1d1a4f95c0ea212",
                    "name": "Chicken"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/api/ingredients": {
      "get": {
        "tags": ["Ingredients"],
        "summary": "Get all ingredients",
        "description": "Returns ingredient catalog available for recipes.",
        "responses": {
          "200": {
            "description": "Ingredients list returned",
            "schema": {
              "$ref": "#/definitions/IngredientCollectionEnvelopeResponse"
            },
            "examples": {
              "application/json": {
                "message": "List of ingredients",
                "data": [
                  {
                    "_id": "686f6e9ac1d1a4f95c0ea311",
                    "name": "Tomato",
                    "desc": "Fresh red tomato",
                    "img": "https://example.com/images/tomato.png"
                  },
                  {
                    "_id": "686f6e9ac1d1a4f95c0ea312",
                    "name": "Olive oil",
                    "desc": "Extra virgin olive oil",
                    "img": "https://example.com/images/olive-oil.png"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/api/recipes": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Search recipes",
        "description": "Public endpoint for recipe search with pagination and filters.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 1
          },
          {
            "name": "perPage",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 12
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "type": "string",
            "example": "Chicken"
          },
          {
            "name": "ingredients",
            "in": "query",
            "required": false,
            "type": "string",
            "example": "Tomato"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "type": "string",
            "example": "bowl"
          }
        ],
        "responses": {
          "200": {
            "description": "Recipes returned",
            "schema": {
              "$ref": "#/definitions/RecipesSearchResponse"
            }
          }
        }
      }
    },
    "/api/recipes/favorites": {
      "get": {
        "tags": ["Favorites"],
        "summary": "Get favorite recipes",
        "description": "Returns authenticated user's favorite recipes with pagination. Login first in this Swagger UI session so cookies are sent automatically.",
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 1
          },
          {
            "name": "perPage",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 12
          }
        ],
        "responses": {
          "200": {
            "description": "Favorite recipes returned",
            "schema": {
              "$ref": "#/definitions/FavoriteRecipesResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/recipes/{recipeId}": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Get recipe by id",
        "description": "Returns detailed recipe by id.",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "type": "string",
            "example": "64f1234567890abcdef1234"
          }
        ],
        "responses": {
          "200": {
            "description": "Recipe returned",
            "schema": {
              "$ref": "#/definitions/RecipeResponse"
            }
          },
          "404": {
            "description": "Recipe not found",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/recipes/my": {
      "post": {
        "tags": ["Recipes"],
        "summary": "Create your own recipe",
        "description": "Private endpoint to create a custom recipe. Login first in this Swagger UI session so cookies are sent automatically. Supports multipart/form-data with optional thumb file.",
        "consumes": ["multipart/form-data"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "title",
            "in": "formData",
            "required": true,
            "type": "string",
            "example": "Herb Chicken Bowl"
          },
          {
            "name": "category",
            "in": "formData",
            "required": true,
            "type": "string",
            "description": "Category ObjectId",
            "example": "6462a6cd4c3d0ddd28897f8d"
          },
          {
            "name": "instructions",
            "in": "formData",
            "required": true,
            "type": "string",
            "description": "Max 1200 characters",
            "example": "Cook chicken, slice vegetables, combine and serve."
          },
          {
            "name": "description",
            "in": "formData",
            "required": true,
            "type": "string",
            "description": "Max 200 characters",
            "example": "Protein-rich bowl with fresh herbs and lemon dressing."
          },
          {
            "name": "time",
            "in": "formData",
            "required": true,
            "type": "number",
            "description": "Integer from 1 to 360",
            "example": 30
          },
          {
            "name": "calories",
            "in": "formData",
            "required": false,
            "type": "number",
            "description": "Integer from 1 to 10000",
            "example": 450
          },
          {
            "name": "ingredients",
            "in": "formData",
            "required": true,
            "type": "string",
            "description": "JSON string with ingredients array (2..16 unique ids)",
            "example": "[{\"id\":\"64f1234567890abcdef1234\",\"measure\":\"200g\"},{\"id\":\"64f1234567890abcdef1235\",\"measure\":\"1 tsp\"}]"
          },
          {
            "name": "thumb",
            "in": "formData",
            "required": false,
            "type": "file",
            "description": "Recipe image file"
          }
        ],
        "responses": {
          "201": {
            "description": "Recipe created",
            "schema": {
              "$ref": "#/definitions/CreateRecipeSuccessResponse"
            },
            "examples": {
              "application/json": {
                "message": "Recipe created successfully",
                "data": {
                  "_id": "686f6e9ac1d1a4f95c0ea411",
                  "title": "Herb Chicken Bowl",
                  "category": "Chicken",
                  "owner": "686f6e9ac1d1a4f95c0ea111",
                  "instructions": "Cook chicken, slice vegetables, combine and serve.",
                  "description": "Protein-rich bowl with fresh herbs and lemon dressing.",
                  "thumb": "https://example.com/images/chicken-bowl.jpg",
                  "time": "30",
                  "calories": 450,
                  "ingredients": [
                    {
                      "id": "64f1234567890abcdef1234",
                      "measure": "200g"
                    }
                  ],
                  "createdAt": "2026-06-13T10:20:00.000Z",
                  "updatedAt": "2026-06-13T10:20:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      },
      "get": {
        "tags": ["Recipes"],
        "summary": "Get my recipes",
        "description": "Returns authenticated user's own recipes with pagination. Login first in this Swagger UI session so cookies are sent automatically.",
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 1
          },
          {
            "name": "perPage",
            "in": "query",
            "required": false,
            "type": "number",
            "example": 12
          }
        ],
        "responses": {
          "200": {
            "description": "My recipes returned",
            "schema": {
              "$ref": "#/definitions/RecipesSearchResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "404": {
            "description": "Recipes not found",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      }
    },
    "/api/recipes/favorites/{recipeId}": {
      "post": {
        "tags": ["Favorites"],
        "summary": "Add recipe to favorites",
        "description": "Adds selected recipe to authenticated user's favorites. Login first in this Swagger UI session so cookies are sent automatically.",
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "type": "string",
            "example": "64f1234567890abcdef1234"
          }
        ],
        "responses": {
          "200": {
            "description": "Recipe added to favorites",
            "schema": {
              "$ref": "#/definitions/FavoriteSuccessResponse"
            },
            "examples": {
              "application/json": {
                "message": "Recipe added to favorites"
              }
            }
          },
          "400": {
            "description": "Recipe already in favorites",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "404": {
            "description": "Recipe not found",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          }
        }
      },
      "delete": {
        "tags": ["Favorites"],
        "summary": "Remove recipe from favorites",
        "description": "Removes selected recipe from authenticated user's favorites. Login first in this Swagger UI session so cookies are sent automatically.",
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
