{
  "openapi": "3.0.0",
  "info": {
    "title": "Tasteorama API 🍽️",
    "version": "1.0.0",
    "description": "Сучасний REST API для пошуку рецептів, керування інгредієнтами та персоналізованого кулінарного досвіду.",
    "license": {
      "name": "FS123"
    }
  },
  "servers": [
    {
      "url": "https://tasteorama-backend-jumn.onrender.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "LocalHost"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Реєстрація, вхід, оновлення сесії, вихід"
    },
    {
      "name": "Users",
      "description": "Профіль поточного користувача"
    },
    {
      "name": "Recipes",
      "description": "Перегляд та створення рецептів"
    },
    {
      "name": "Favorites",
      "description": "Управління улюбленими рецептами"
    },
    {
      "name": "My Recipes",
      "description": "Рецепти поточного користувача"
    },
    {
      "name": "Categories",
      "description": "Список категорій"
    },
    {
      "name": "Ingredients",
      "description": "Список інгредієнтів"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken"
      }
    },
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "name": {
            "type": "string",
            "example": "Beef"
          }
        }
      },
      "Ingredient": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "name": {
            "type": "string",
            "example": "Chicken"
          },
          "desc": {
            "type": "string",
            "example": "Fresh chicken breast"
          },
          "img": {
            "type": "string",
            "example": "https://example.com/chicken.jpg"
          }
        }
      },
      "RecipeIngredient": {
        "type": "object",
        "required": ["id", "measure"],
        "properties": {
          "id": {
            "type": "string",
            "description": "ID інгредієнта з колекції ingredients",
            "example": "6462a8f74c3d0ddd28897aaa"
          },
          "measure": {
            "type": "string",
            "maxLength": 10,
            "example": "500g"
          }
        }
      },
      "Recipe": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "title": {
            "type": "string",
            "example": "Chicken Pasta"
          },
          "category": {
            "type": "string",
            "description": "Назва категорії з колекції categories",
            "example": "Chicken"
          },
          "owner": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "area": {
            "type": "string",
            "example": "British"
          },
          "instructions": {
            "type": "string",
            "example": "Cook pasta, add chicken, mix sauce"
          },
          "description": {
            "type": "string",
            "example": "Delicious Italian pasta with chicken"
          },
          "thumb": {
            "type": "string",
            "example": "https://res.cloudinary.com/example/pasta.jpg"
          },
          "time": {
            "type": "string",
            "example": "30"
          },
          "calories": {
            "type": "number",
            "example": 450
          },
          "ingredients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecipeIngredient"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserFavorite": {
        "type": "object",
        "properties": {
          "recipeId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "402f5f45bcf16cd539439043"
          },
          "name": {
            "type": "string",
            "example": "Dan Balan"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "balan@example.com"
          },
          "favorites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFavorite"
            }
          },
          "avatar": {
            "type": "string",
            "example": "https://ac.goit.global/fullstack/react/default-avatar.jpg"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Information about the current user"
          },
          "data": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "RecipeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Recipe Information"
          },
          "data": {
            "$ref": "#/components/schemas/Recipe"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Operation completed successfully"
          }
        }
      },
      "CategoriesResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "List of categories"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          }
        }
      },
      "IngredientsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "List of ingredients"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ingredient"
            }
          }
        }
      },
      "PaginatedRecipes": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "List of recipes"
          },
          "page": {
            "type": "number",
            "example": 1
          },
          "perPage": {
            "type": "number",
            "example": 12
          },
          "totalItems": {
            "type": "number",
            "example": 42
          },
          "totalPages": {
            "type": "number",
            "example": 4
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Recipe"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "number",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "Error message"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Реєстрація нового користувача",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 16,
                    "example": "Dan Balan"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 128,
                    "example": "balan@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "example": "pa777sss"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Користувач успішно зареєстрований. Сесійні cookies встановлені.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                },
                "example": {
                  "message": "Information about the new user",
                  "data": {
                    "_id": "402f5f45bcf16cd539439043",
                    "name": "Dan Balan",
                    "email": "balan@example.com",
                    "favorites": [],
                    "avatar": "https://ac.goit.global/fullstack/react/default-avatar.jpg"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Email вже використовується або некоректні дані",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 400,
                  "message": "Email in use"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Вхід в акаунт",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 128,
                    "example": "balan@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "example": "pa777sss"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успішний вхід. Сесійні cookies встановлені.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                },
                "example": {
                  "message": "Information about the current user",
                  "data": {
                    "_id": "402f5f45bcf16cd539439043",
                    "name": "Dan Balan",
                    "email": "balan@example.com",
                    "favorites": [],
                    "avatar": "https://ac.goit.global/fullstack/react/default-avatar.jpg"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Невірні облікові дані",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Invalid credentials"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Оновлення сесії",
        "description": "Оновлює accessToken і refreshToken через cookies. Потребує наявних cookies: sessionId, refreshToken.",
        "responses": {
          "200": {
            "description": "Сесія успішно оновлена",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "message": "Session refreshed"
                }
              }
            }
          },
          "401": {
            "description": "Відсутні cookies або сесія закінчилась",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing": {
                    "value": {
                      "status": 401,
                      "message": "Missing session credentials"
                    }
                  },
                  "expired": {
                    "value": {
                      "status": 401,
                      "message": "Session token expired"
                    }
                  },
                  "notFound": {
                    "value": {
                      "status": 401,
                      "message": "Session not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Вихід з акаунта",
        "description": "Видаляє сесію та очищає cookies. Вимагає аутентифікації.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Успішний вихід, тіло відповіді відсутнє"
          },
          "401": {
            "description": "Не аутентифікований",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["Users"],
        "summary": "Отримати поточного користувача",
        "description": "Повертає інформацію про поточного авторизованого користувача без конфіденційних даних.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Дані поточного користувача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                },
                "example": {
                  "message": "Information about the current user",
                  "data": {
                    "_id": "402f5f45bcf16cd539439043",
                    "name": "Dan Balan",
                    "email": "balan@example.com",
                    "favorites": [],
                    "avatar": "https://ac.goit.global/fullstack/react/default-avatar.jpg"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Не аутентифікований",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/recipes": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Отримати всі рецепти",
        "description": "Отримання колекції рецептів із підтримкою фільтрації та пагінації.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "example": 1
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 5,
              "maximum": 20,
              "default": 12
            },
            "example": 12
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "example": "Chicken",
            "description": "Фільтр за назвою категорії"
          },
          {
            "name": "ingredients",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "example": "",
            "description": "Фільтр за назвою інгредієнта"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "example": "Beef Stew",
            "description": "Пошук за назвою рецепта"
          }
        ],
        "responses": {
          "200": {
            "description": "Список рецептів з пагінацією",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedRecipes"
                },
                "example": {
                  "message": "List of recipes",
                  "page": 1,
                  "perPage": 12,
                  "totalItems": 42,
                  "totalPages": 4,
                  "data": []
                }
              }
            }
          },
          "404": {
            "description": "Рецепти не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Recipes not found"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Recipes"],
        "summary": "Створити новий рецепт",
        "description": "Створення нового рецепта доступне лише для авторизованих користувачів. Зображення завантажується у форматі multipart/form-data, а список інгредієнтів передається у вигляді JSON-рядка.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "description",
                  "time",
                  "category",
                  "ingredients",
                  "instructions"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 64,
                    "example": "Beef Stew"
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 200,
                    "example": "Delicious beef soup with vegetables"
                  },
                  "time": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 360,
                    "example": 90
                  },
                  "calories": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 10000,
                    "example": 650
                  },
                  "category": {
                    "type": "string",
                    "description": "Назва категорії з колекції categories",
                    "example": "Chicken"
                  },
                  "ingredients": {
                    "type": "string",
                    "description": "JSON-рядок масиву інгредієнтів: від 2 до 16 елементів. Кожен елемент містить id та measure. measure: string, max 10 символів.",
                    "example": "[{\"id\":\"6462a8f74c3d0ddd28897aaa\",\"measure\":\"500g\"},{\"id\":\"6462a8f74c3d0ddd28897bbb\",\"measure\":\"2 pcs\"}]"
                  },
                  "instructions": {
                    "type": "string",
                    "maxLength": 1200,
                    "example": "Cut beef, boil water, add vegetables and cook for 90 minutes."
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Рецепт створено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecipeResponse"
                },
                "example": {
                  "message": "Recipe created successfully",
                  "data": {
                    "_id": "507f1f77bcf86cd799439011",
                    "title": "Beef Stew",
                    "category": "Beef",
                    "thumb": "https://res.cloudinary.com/example/beef-stew.jpg"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Некоректні дані рецепта, категорія або інгредієнти",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalidCategory": {
                    "value": {
                      "status": 400,
                      "message": "Invalid category"
                    }
                  },
                  "invalidIngredients": {
                    "value": {
                      "status": 400,
                      "message": "Ingredients must be a valid JSON string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Не аутентифікований",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/recipes/{recipeId}": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Отримати рецепт за ID",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "6462a8f74c3d0ddd28897fcd"
          }
        ],
        "responses": {
          "200": {
            "description": "Рецепт знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecipeResponse"
                },
                "example": {
                  "message": "Recipe Information",
                  "data": {
                    "_id": "6462a8f74c3d0ddd28897fcd",
                    "title": "Chicken Pasta",
                    "category": "Chicken",
                    "thumb": "https://res.cloudinary.com/example/pasta.jpg"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Рецепт не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Recipe not found"
                }
              }
            }
          }
        }
      }
    },
    "/recipes/favorites": {
      "get": {
        "tags": ["Favorites"],
        "summary": "Отримати улюблені рецепти",
        "description": "Повертає рецепти зі списку favorites поточного користувача з пагінацією.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "example": 1
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 12
            },
            "example": 12
          }
        ],
        "responses": {
          "200": {
            "description": "Список улюблених рецептів",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedRecipes"
                },
                "example": {
                  "message": "List of favorite recipes",
                  "page": 1,
                  "perPage": 12,
                  "totalItems": 3,
                  "totalPages": 1,
                  "data": []
                }
              }
            }
          },
          "401": {
            "description": "Не аутентифікований",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Користувача або рецепти не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "userNotFound": {
                    "value": {
